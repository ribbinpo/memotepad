{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "memotepad",
  "version": "0.2.0",
  "identifier": "com.poom.memotepad",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 360,
        "height": 420,
        "minWidth": 240,
        "minHeight": 200,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
